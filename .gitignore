# =============================================================================
# LinkTrack – .gitignore
# Stack: Next.js 14 / TypeScript / Tailwind / Supabase / Vercel
# =============================================================================

# -----------------------------------------------------------------------------
# Dependencies
# -----------------------------------------------------------------------------
node_modules/
.pnp
.pnp.js
.yarn/install-state.gz

# -----------------------------------------------------------------------------
# Next.js
# -----------------------------------------------------------------------------
.next/
out/
build/
dist/

# Next.js cache / telemetry
.next/cache/
.vercel/output/

# Next.js static export
/out

# -----------------------------------------------------------------------------
# Environment Variables  ← never commit secrets
# -----------------------------------------------------------------------------
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env*.local

# Keep the example file committed as a reference
!.env.example
!.env.local.example

# -----------------------------------------------------------------------------
# Supabase
# -----------------------------------------------------------------------------
# Local Supabase dev stack (docker volumes, postgres data, etc.)
supabase/.branches/
supabase/.temp/
supabase/functions/.cache/

# Supabase CLI auth token (written to ~/.supabase, but guard local overrides)
.supabase/

# Generated Supabase types (regenerate via CLI – do NOT commit if auto-generated)
# Uncomment the line below if you regenerate types in CI instead of committing them:
# src/types/supabase.ts

# -----------------------------------------------------------------------------
# Vercel
# -----------------------------------------------------------------------------
.vercel/
.vercel

# -----------------------------------------------------------------------------
# TypeScript
# -----------------------------------------------------------------------------
*.tsbuildinfo
next-env.d.ts

# -----------------------------------------------------------------------------
# Testing
# -----------------------------------------------------------------------------
coverage/
.nyc_output/
/test-results/
/playwright-report/
/playwright/.cache/
*.lcov

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# -----------------------------------------------------------------------------
# OS / Editor artifacts
# -----------------------------------------------------------------------------

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
Thumbs.db:encryptionKey
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~

# VSCode
.vscode/
!.vscode/extensions.json
!.vscode/settings.json.example

# JetBrains / IntelliJ
.idea/
*.iml
*.ipr
*.iws

# Vim / Emacs swap files
*.swp
*.swo
*.swn
[._]*.s[a-v][a-z]
[._]*.sw[a-p]
Session.vim
.netrwhist

# -----------------------------------------------------------------------------
# Package manager lock files  (keep ONE; ignore the others)
# Adjust to whichever lock file your project commits.
# -----------------------------------------------------------------------------
# Uncomment the lines for the lock files you do NOT use:
# package-lock.json   # keep if using npm
# yarn.lock           # keep if using yarn
# pnpm-lock.yaml      # keep if using pnpm

# -----------------------------------------------------------------------------
# Miscellaneous build / tooling
# -----------------------------------------------------------------------------
.cache/
.parcel-cache/
.turbo/
.eslintcache
.stylelintcache
.prettiercache
storybook-static/
